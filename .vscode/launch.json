{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Customer API (FastAPI)",
        "type": "debugpy",
        "request": "launch",
        "python": "${workspaceFolder}/backend/customer/.venv/bin/python",
        "module": "uvicorn",
        "cwd": "${workspaceFolder}/backend/customer",
        "args": ["app.main:app", "--host", "0.0.0.0", "--port", "8081", "--reload"],
        "justMyCode": true,
        "consoleTitle": "customer"
        
      },
      {
        "name": "Gateway API (FastAPI)",
        "type": "debugpy",
        "request": "launch",
        "python": "${workspaceFolder}/backend/gateway/.venv/bin/python",
        "module": "uvicorn",
        "cwd": "${workspaceFolder}/backend/gateway",
        "args": ["app.main:app", "--host", "0.0.0.0", "--port", "8080", "--reload"],
        "justMyCode": true,
        "consoleTitle": "gateway"
      },
      {
        "name": "Frontend (npm run dev)",
        "type": "node-terminal",
        "request": "launch",
        "command": "npm run dev",
        "cwd": "${workspaceFolder}/frontend"
      }
    ],
    "compounds": [
      {
        "name": "Run Full Stack",
        "configurations": [
          "Customer API (FastAPI)",
          "Gateway API (FastAPI)",
          "Frontend (npm run dev)"
        ]
      }
    ]
  }